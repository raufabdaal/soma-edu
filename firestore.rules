rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User Profiles
    match /users/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow read if user is looking at their own profile, OR if they are an authenticated parent
      // (Parents need to read names of linked students)
      allow read: if request.auth != null;
    }

    // Student Documents
    match /students/{studentId} {
      // Allow student to manage their own document
      allow write: if request.auth != null && request.auth.uid == studentId;
      // Allow authenticated users (parents) to link by adding themselves to parentIds
      // We allow updates to parentIds if the user is authenticated.
      // In a production app, we would strictly validate that they are only adding THEIR OWN uid.
      allow update: if request.auth != null &&
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['parentIds']) ||
                     request.auth.uid == studentId);

      // Allow read if authenticated (needed for client-side linking/lookup)
      allow read: if request.auth != null;

      // Special rule for the linking query (list search by studyCode)
      allow list: if request.auth != null;
    }

    // Parent Documents
    match /parents/{parentId} {
      allow read, write: if request.auth != null && request.auth.uid == parentId;
    }

    // Learning Content (Read-only for students/parents, write allowed for authorized initial seeding)
    match /subjects/{document=**} { 
      allow read: if request.auth != null; 
      allow write: if request.auth != null; 
    }
    match /topics/{document=**} { 
      allow read: if request.auth != null; 
      allow write: if request.auth != null; 
    }
    match /lessons/{document=**} { 
      allow read: if request.auth != null; 
      allow write: if request.auth != null; 
    }
    match /questions/{document=**} { 
      allow read: if request.auth != null; 
      allow write: if request.auth != null; 
    }
    match /markingSchemes/{document=**} { 
      allow read: if request.auth != null; 
      allow write: if request.auth != null; 
    }

    // Progress Data (Subcollections under students)
    match /students/{studentId}/progress/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
      allow read: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/students/$(studentId)).data.parentIds);
    }

    // Additional progress collections if used
    match /students/{studentId}/progress_subjects/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
      allow read: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/students/$(studentId)).data.parentIds);
    }

    // Topic-level progress tracking
    match /students/{studentId}/progress_topics/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
      allow read: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/students/$(studentId)).data.parentIds);
    }

    // Reports
    match /weeklyReports/{reportId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid in get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentIds
      );
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.studentId ||
        request.auth.uid == userId // where userId is passed in doc
      );
    }
  }
}
