# Firebase Configuration (Get these from Firebase Console -> Project Settings)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Nvidia AI (Get from Nvidia NIM - https://build.nvidia.com/explore/discover)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Email (Get from Resend - https://resend.com/)
RESEND_API_KEY=your_resend_api_key_here

# Internal Security & Cron (Choose any secure strings)
ADMIN_SECRET=your_admin_secret_here
CRON_SECRET=your_cron_secret_here
